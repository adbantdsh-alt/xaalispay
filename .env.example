# ═══════════════════════════════════════════════════════════════
# XaalisPay — Variables d'environnement
# Copier vers .env.local (dev) ou Vercel → Settings → Environment Variables (prod)
# ═══════════════════════════════════════════════════════════════

# URL publique officielle (liens partagés + confirmation email Supabase)
NEXT_PUBLIC_SITE_URL=https://xaalispay.com

# Supabase (requis en production)
# Dashboard Supabase → Authentication → URL Configuration :
#   Site URL : https://xaalispay.com
#   Redirect URLs : https://xaalispay.com/auth/callback
# SQL Editor : exécuter supabase/setup_prod.sql (app_state + bucket images)
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key

# Retraits Wave/Orange (requis pour virements réels)
PAYMENT_WITHDRAW_API_URL=

# Bictorys PRODUCTION (remplacer les clés test)
BICTORYS_PUBLIC_KEY=
BICTORYS_API_KEY=
BICTORYS_BASE_URL=https://api.bictorys.com
BICTORYS_WEBHOOK_SECRET=

# Bictorys retraits / remboursements
BICTORYS_PAYOUT_API_KEY=
BICTORYS_PAYOUT_WEBHOOK_SECRET=
BICTORYS_PAYOUT_SECRET_CODE=
BICTORYS_REFUND_API_KEY=
BICTORYS_REFUND_WEBHOOK_SECRET=

# Séquestre Flash : minutes après validation PIN avant libération vendeur
PROTECTION_MINUTES=30

# Cron Vercel — requis en production pour /api/maintenance
# Vercel envoie : Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# ── Dev uniquement (NE PAS activer en production) ──
DEV_AUTO_LOGIN=false

# Secret session JWT locale (obligatoire en prod, min. 32 caractères)
AUTH_SECRET=

# ═══════════════════════════════════════════════════════════════
# Checklist prod (vérifier aussi dans /admin → Vue d'ensemble)
# [ ] supabase/setup_prod.sql exécuté
# [ ] DEV_AUTO_LOGIN=false
# [ ] AUTH_SECRET + CRON_SECRET définis
# [ ] BICTORYS_* = clés prod (pas test.bictorys.com)
# [ ] BICTORYS_WEBHOOK_SECRET configuré
# [ ] Vercel Cron → GET /api/maintenance (toutes les heures)
# ═══════════════════════════════════════════════════════════════

# SEO — Google Search Console (optionnel)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=votre_code_verification
