# URL publique officielle (liens partagés + confirmation email Supabase)
NEXT_PUBLIC_SITE_URL=https://xaalispay.com

# Supabase (requis pour l'auth vendeur)
# Dashboard Supabase → Authentication → URL Configuration :
#   Site URL : https://xaalispay.com
#   Redirect URLs : https://xaalispay.com/auth/callback
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key
# Clé service (Settings → API) : confirme les comptes + persistance produits (table app_state)
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key

# Retraits Wave/Orange (optionnel — laisser vide = mode file d'attente)
PAYMENT_WITHDRAW_API_URL=

# Bictorys (paiements — mode TEST)
BICTORYS_API_KEY=
BICTORYS_PUBLIC_KEY=
BICTORYS_BASE_URL=https://api.test.bictorys.com
BICTORYS_WEBHOOK_SECRET=

# Séquestre Flash : minutes après validation PIN avant libération vendeur
PROTECTION_MINUTES=30
