# ═══════════════════════════════════════════════════════════════
# XaalisPay (frontend) — Variables d'environnement
# Copier vers .env.local
# ═══════════════════════════════════════════════════════════════

# URL publique officielle (liens partagés)
NEXT_PUBLIC_SITE_URL=https://xaalispay.com

# Backend Django (xaalispay-backend) — auth, commandes, paiements, wallet,
# upload d'images produit (Cloudinary)... Utilisé à la fois côté serveur
# (routes proxy app/api/auth/*) et côté client (appels directs navigateur
# → Django, voir src/lib/api-client.ts).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# SEO — Google Search Console (optionnel)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=votre_code_verification
